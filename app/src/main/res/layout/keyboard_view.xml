<?xml version="1.0" encoding="utf-8"?>
<com.apuroops.shruggie.KeyboardRootLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="8dp">

    <Button
        android:id="@+id/shrug_button"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:layout_marginBottom="6dp"
        android:background="@drawable/btn_shrug_background"
        android:stateListAnimator="@null"
        android:text="@string/shruggie"
        android:textColor="#FFFFFF"
        android:textSize="28sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <Button
            android:id="@+id/return_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_shrug_background"
            android:stateListAnimator="@null"
            android:text="↵"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <Button
            android:id="@+id/space_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_shrug_background"
            android:stateListAnimator="@null"
            android:text="space"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <Button
            android:id="@+id/backspace_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/btn_shrug_background"
            android:stateListAnimator="@null"
            android:text="⌫"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

    </LinearLayout>

</com.apuroops.shruggie.KeyboardRootLayout>
